# .env.example — Template file. Copy to .env.local and fill in your values.
# Do NOT commit .env.local — it contains real secrets.
# This file MUST be committed: it documents all required environment variables.

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=web-documents

# ─── Session ───────────────────────────────────────────────────────────────────
# Must be a random hex string of 32+ characters.
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-generate-with-openssl-rand-hex-32

# ─── AWS S3 / RustFS ───────────────────────────────────────────────────────────
AWS_USERNAME=your-access-key-here
AWS_PASSWORD=your-secret-key-here
AWS_REGION=us-east-1
AWS_URL=http://localhost:10000
AWS_BUCKET=ia4devs-storage

# ─── Email (MailHog) ───────────────────────────────────────────────────────────
MAILHOG_HOST=localhost
MAIL_PORT=1027

# ─── Next.js ───────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000
